#!/usr/bin/env bash

set -euo pipefail

# shellcheck disable=SC2329
on_interrupt() {
    trap - INT TERM
    echo "Script interrupted." >&2
    exit 130
}
trap on_interrupt INT TERM

if [ "$EUID" -ne 0 ]; then
    SCRIPT_USER="$USER"
    SCRIPT_HOME="$HOME"
    SCRIPT_SUDO=false

    echo "This script requires sudo privileges."
    echo "Requesting sudo privileges... (Press Ctrl+C to cancel)"

    if ! sudo -v &> /dev/null; then
        echo "Failed to obtain sudo privileges." >&2
        autostart_prompt
        exit 1
    fi

    echo "Sudo privileges granted."

    sudo_keepalive() {
        while sleep 60; do
            sudo -n true || exit
        done
    }
    sudo_keepalive &
    SUDO_LOOP_PID=$!

    # shellcheck disable=SC2329

    cleanup() {
        if ! $SCRIPT_SUDO; then
            sudo kill "$SUDO_LOOP_PID" 2>/dev/null || true
            sudo -K || true
        fi
    }
    trap cleanup EXIT
else
    SCRIPT_USER="$SUDO_USER"
    SCRIPT_HOME="$SUDO_HOME"
    SCRIPT_SUDO=true
fi

ACTUAL_SCRIPT_NAME=$(basename "$0")
CLEANED_SCRIPT_NAME="${ACTUAL_SCRIPT_NAME#[0-9]*-}"
SCRIPT_STATE="/var/lib/dank-bluebuild/post-login-setup/script.d/$CLEANED_SCRIPT_NAME.completed"
SCRIPT_HOME_STATE="$SCRIPT_HOME/.local/state/dank-bluebuild/post-login-setup/script.d/$CLEANED_SCRIPT_NAME.completed"

if [ -f "$SCRIPT_STATE" ] || [ -f "$SCRIPT_HOME_STATE" ]; then
    echo "Script '$CLEANED_SCRIPT_NAME' already completed."
    exit 0
fi

failed() {
    echo "Failed to restore $SCRIPT_USER's backup." >&2
    exit 1
}

echo "Attempting to restore $SCRIPT_USER's backup..."

TEMP_MOUNTPOINT=$(mktemp -d)
if sudo mount -o subvolid=5 -L WD-1TB "$TEMP_MOUNTPOINT"; then
    echo "Temporarily mounted WD-1TB at '$TEMP_MOUNTPOINT'."
else
    echo "Failed to mount WD-1TB at '$TEMP_MOUNTPOINT'." >&2
    failed
fi

# shellcheck disable=SC2329
cleanup() {
    sudo umount "$TEMP_MOUNTPOINT" 2>/dev/null || true
    sudo rmdir "$TEMP_MOUNTPOINT" 2>/dev/null || true
}
trap cleanup EXIT

if sudo btrfs subvolume list "$TEMP_MOUNTPOINT"  | awk '{print $NF}' | grep -qx "@samsung_backup"; then
    echo "Confirmed that Btrfs subvolume '@samsung_backup' exists in WD-1TB."
else
    echo "Btrfs subvolume '@samsung_backup' does not exist in WD-1TB."
    echo "Nothing to restore."
    failed
fi

if sudo -u "$SCRIPT_USER" mountpoint -q "$SCRIPT_HOME/.mount/SAMSUNG@STORAGE"; then
    echo "Confirmed that '~/.mount/SAMSUNG@STORAGE' is a successful mountpoint."
else
    echo "Nothing was mounted at '~/.mount/SAMSUNG@STORAGE'."
    echo "Nowhere to restore to."
    failed
fi

echo "Rsync starting..."

if sudo rsync -ah --info=progress2 "$TEMP_MOUNTPOINT"/@samsung_backup/ "$SCRIPT_HOME"/.mount/SAMSUNG@STORAGE/; then
    echo "Successfully restored data from '@samsung_backup' to '~/.mount/SAMSUNG@STORAGE'."
else
    echo "Failed to restore data from '@samsung_backup' to '~/.mount/SAMSUNG@STORAGE'." >&2
    failed
fi

echo "Sucessfully restored $SCRIPT_USER's backup."

mkdir -p "$(dirname "$SCRIPT_HOME_STATE")"
touch "$SCRIPT_HOME_STATE"
exit 0
